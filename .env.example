# Copy this file to .env and fill in the values before running docker compose.
# cp .env.example .env

# ── Control panel credentials ─────────────────────────────────────────────────
# IMPORTANT: change the password before any internet-facing deployment.
PANEL_ADMIN_USERNAME=admin
PANEL_ADMIN_PASSWORD=change-me

# ── Control panel port ────────────────────────────────────────────────────────
# Host port for direct access. Browse to http://localhost:5099 to open the panel.
# Behind a reverse proxy (Caddy, nginx) set to any unused port and proxy to it.
PANEL_PORT=5099

# ── Docker socket (docker-agent) ─────────────────────────────────────────────
# Leave empty to use the Unix socket mount (/var/run/docker.sock).
# Docker Desktop on Windows: enable "Allow the default Docker socket to be used"
# in Docker Desktop settings, OR uncomment the TCP line below.
# On rootless Linux Docker, set DOCKER_SOCKET_PATH=/run/user/<uid>/docker.sock
# and keep DOCKER_HOST empty.
#DOCKER_SOCKET_PATH=/var/run/docker.sock
#DOCKER_HOST=tcp://host.docker.internal:2375

# Dedicated game servers in this project are distributed as x86/x86_64 binaries.
# Keep linux/amd64 on ARM VPS hosts unless you know a specific image supports ARM.
GAME_SERVER_PLATFORM=linux/amd64

# ── Quake Live server ─────────────────────────────────────────────────────────
# Docker image tag for the Quake Live server (built by docker compose build).
QL_IMAGE=quake-live-server:latest

# UDP/TCP port for Quake Live game traffic (players connect here).
QL_SERVER_PORT=27970

# TCP port for ZMQ RCON (remote control).
QL_RCON_PORT=28970

# ── Reflex Arena server ───────────────────────────────────────────────────────
# Docker image tag for the Reflex Arena server (built by docker compose build).
REFLEX_IMAGE=reflex-arena-server:latest

# UDP/TCP port for Reflex Arena game traffic.
REFLEX_SERVER_PORT=25787

# ── Warsow game server ────────────────────────────────────────────────────────
# Docker image tag for the Warsow server (built by docker compose build).
WARSOW_IMAGE=warsow-server:latest

# UDP port for Warsow game traffic (players connect here).
WARSOW_SERVER_PORT=44400

# TCP port for Warsow HTTP server (map downloads etc.).
WARSOW_HTTP_PORT=44444

# ── Warfork game server ───────────────────────────────────────────────────────
# Docker image tag for the Warfork server (built by docker compose build).
WARFORK_IMAGE=warfork-server:latest

# UDP port for Warfork game traffic (players connect here).
WARFORK_SERVER_PORT=44500

# TCP port for Warfork HTTP server (downloads etc.).
WARFORK_HTTP_PORT=44544
