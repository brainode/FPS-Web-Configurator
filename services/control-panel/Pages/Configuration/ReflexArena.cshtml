@page
@model control_panel.Pages.Configuration.ReflexArenaModel
@{
    ViewData["Title"] = "Reflex Arena";
}

<section class="page-shell py-4 py-lg-5">
    <div class="container-xxl">
        <div class="page-header d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
            <div>
                <span class="section-kicker">Reflex Arena</span>
                <h1 class="page-title mb-2">Server Parameters</h1>
                <p class="page-subtitle mb-0">Configure startup mode, opening map and access controls from one clean administrative surface.</p>
            </div>
            <div class="d-flex gap-2 align-items-center">
                <div class="status-chip @Model.StatusToneClass">
                    <span class="status-dot"></span>
                    <span>@Model.Status.StateLabel</span>
                </div>
                <a class="btn btn-outline-light" asp-page="/Index">Back to dashboard</a>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="alert alert-success border-0 panel-alert" role="alert">@Model.SuccessMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger border-0 panel-alert" role="alert">@Model.ErrorMessage</div>
        }

        <div class="panel-card mb-4">
            <div class="panel-card-header">
                <span class="section-kicker">Container</span>
                <h2 class="panel-title">Server control</h2>
            </div>
            <div class="panel-card-body">
                <div class="d-flex flex-wrap gap-2">
                    @if (Model.CanStart)
                    {
                        <form method="post" asp-page-handler="Start">
                            <button type="submit" class="btn btn-primary btn-lg">Start server</button>
                        </form>
                    }

                    @if (Model.CanRestart)
                    {
                        <form method="post" asp-page-handler="Restart">
                            <button type="submit" class="btn btn-outline-warning" data-confirm-restart="true">Restart server</button>
                        </form>
                    }

                    @if (Model.CanStop)
                    {
                        <form method="post" asp-page-handler="Stop">
                            <button type="submit" class="btn btn-outline-light">Stop server</button>
                        </form>
                    }

                    @if (Model.ShowUnavailableActions)
                    {
                        <button type="button" class="btn btn-outline-secondary" disabled>Server actions unavailable</button>
                    }
                </div>
            </div>
        </div>

        <form method="post" class="vstack gap-4" data-choice-filter-scope="true">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 panel-alert validation-summary"></div>

            <div class="row g-4">
                <div class="col-12 col-xl-4">
                    <div class="panel-card h-100">
                        <div class="panel-card-header">
                            <span class="section-kicker">Startup</span>
                            <h2 class="panel-title">Mode &amp; opening map</h2>
                            <p class="panel-text mb-0">The map picker updates instantly when you switch modes, so the opening map choices always match the active ruleset.</p>
                        </div>
                        <div class="panel-card-body vstack gap-3">
                            <div>
                                <label asp-for="Input.Mode" class="form-label"></label>
                                <select asp-for="Input.Mode" class="form-select" data-choice-filter-source="true">
                                    @foreach (var mode in Model.ModeOptions)
                                    {
                                        <option value="@mode.Key" data-choice-filter-preferred-value="@mode.RecommendedMap">@mode.Label</option>
                                    }
                                </select>
                                <div class="form-hint">@(Model.ModeOptions.FirstOrDefault(mode => mode.Key == Model.Input.Mode)?.Description ?? string.Empty)</div>
                                <span asp-validation-for="Input.Mode" class="text-danger small"></span>
                            </div>
                            <div>
                                <label asp-for="Input.StartMap" class="form-label"></label>
                                <select asp-for="Input.StartMap" class="form-select" data-choice-filter-target-select="true">
                                    @foreach (var group in Model.MapGroups)
                                    {
                                        <optgroup label="@group.Label">
                                            @foreach (var map in group.Maps)
                                            {
                                                <option value="@map.Key"
                                                        data-choice-filter-values="@string.Join(' ', Model.GetSupportedModesForMap(map.Key))"
                                                        disabled="@(!Model.IsMapSupportedForSelectedMode(map.Key))">@map.Label</option>
                                            }
                                        </optgroup>
                                    }
                                </select>
                                <div class="form-hint">Changing the mode updates the opening map picker immediately. Only maps supported by the selected mode stay enabled.</div>
                                <span asp-validation-for="Input.StartMap" class="text-danger small"></span>
                            </div>
                            <div>
                                <label asp-for="Input.Hostname" class="form-label"></label>
                                <input asp-for="Input.Hostname" class="form-control" />
                                <span asp-validation-for="Input.Hostname" class="text-danger small"></span>
                            </div>
                            <div>
                                <label asp-for="Input.MaxClients" class="form-label"></label>
                                <input asp-for="Input.MaxClients" class="form-control" min="1" max="64" />
                                <span asp-validation-for="Input.MaxClients" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-4">
                    <div class="panel-card h-100">
                        <div class="panel-card-header">
                            <span class="section-kicker">Rules</span>
                            <h2 class="panel-title">Mutators &amp; matchmaking hints</h2>
                            <p class="panel-text mb-0">Mutators come from the stock dedicated server feature set, not from ad-hoc cfg patches.</p>
                        </div>
                        <div class="panel-card-body vstack gap-3">
                            <div class="rule-toggle-list">
                                @foreach (var mutator in Model.MutatorOptions)
                                {
                                    <label class="rule-toggle">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               name="Input.SelectedMutators"
                                               value="@mutator.Key"
                                               @(Model.IsMutatorSelected(mutator.Key) ? "checked" : null) />
                                        <span>
                                            <strong>@mutator.Label</strong>
                                            <small>@mutator.Description</small>
                                        </span>
                                    </label>
                                }
                            </div>
                            <span asp-validation-for="Input.SelectedMutators" class="text-danger small"></span>
                            <div>
                                <label class="rule-toggle">
                                    <input asp-for="Input.SteamEnabled" class="form-check-input" />
                                    <span>
                                        <strong>Publish to Steam browser</strong>
                                        <small>Disable this for direct-connect only sessions.</small>
                                    </span>
                                </label>
                            </div>
                            <div class="row g-3">
                                <div class="col-sm-6">
                                    <label asp-for="Input.Country" class="form-label"></label>
                                    <input asp-for="Input.Country" class="form-control" placeholder="RU" maxlength="3" />
                                    <div class="form-hint">Optional 2-3 letter code shown by Reflex browser tools.</div>
                                    <span asp-validation-for="Input.Country" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label asp-for="Input.TimeLimitOverride" class="form-label"></label>
                                    <input asp-for="Input.TimeLimitOverride" class="form-control" min="0" max="6000" />
                                    <div class="form-hint">Set to <code>0</code> to keep the game's default match timer.</div>
                                    <span asp-validation-for="Input.TimeLimitOverride" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-4">
                    <div class="panel-card h-100">
                        <div class="panel-card-header">
                            <span class="section-kicker">Access</span>
                            <h2 class="panel-title">Passwords &amp; admin control</h2>
                            <p class="panel-text mb-0">Join password is optional. Referee password is required — it doubles as the rcon password used by the entrypoint to load custom maps after startup.</p>
                        </div>
                        <div class="panel-card-body vstack gap-3">
                            <div>
                                <label asp-for="Input.ServerPassword" class="form-label"></label>
                                <div class="input-group password-input-group">
                                    <input id="join-password"
                                           name="Input.ServerPassword"
                                           type="password"
                                           value="@Model.Input.ServerPassword"
                                           class="form-control"
                                           autocomplete="new-password"
                                           placeholder="@(Model.HasJoinPassword ? "Leave empty to keep the join password" : "Optional join password")" />
                                    <button type="button"
                                            class="btn btn-outline-secondary password-toggle"
                                            data-password-toggle="join-password"
                                            aria-label="Show join password">
                                        <svg viewBox="0 0 24 24" class="password-toggle-icon" aria-hidden="true" focusable="false">
                                            <path d="M12 5C6.4 5 2.1 8.4 0 12c2.1 3.6 6.4 7 12 7s9.9-3.4 12-7c-2.1-3.6-6.4-7-12-7Zm0 11.2A4.2 4.2 0 1 1 12 7.8a4.2 4.2 0 0 1 0 8.4Zm0-1.9a2.3 2.3 0 1 0 0-4.6 2.3 2.3 0 0 0 0 4.6Z"></path>
                                        </svg>
                                    </button>
                                </div>
                                <div class="credential-state mt-1">
                                    <span class="status-chip @Model.JoinPasswordStateClass">
                                        <span class="status-dot"></span>
                                        <span>@Model.JoinPasswordStateLabel</span>
                                    </span>
                                    @if (Model.HasJoinPassword)
                                    {
                                        <label class="form-check credential-clear-toggle mt-2">
                                            <input asp-for="Input.ClearServerPassword" class="form-check-input" />
                                            <span class="form-check-label">Clear saved join password and open the lobby</span>
                                        </label>
                                    }
                                </div>
                            </div>

                            <hr class="border-secondary my-1" />

                            <div>
                                <label asp-for="Input.RefPassword" class="form-label"></label>
                                <div class="input-group password-input-group">
                                    <input id="rcon-password"
                                           name="Input.RefPassword"
                                           type="password"
                                           value="@Model.Input.RefPassword"
                                           class="form-control"
                                           autocomplete="new-password"
                                           placeholder="@(Model.HasConfiguredRefPassword ? "Leave empty to keep the current password" : "Set referee / rcon password")" />
                                    <button type="button"
                                            class="btn btn-outline-secondary password-toggle"
                                            data-password-toggle="rcon-password"
                                            aria-label="Show referee password">
                                        <svg viewBox="0 0 24 24" class="password-toggle-icon" aria-hidden="true" focusable="false">
                                            <path d="M12 5C6.4 5 2.1 8.4 0 12c2.1 3.6 6.4 7 12 7s9.9-3.4 12-7c-2.1-3.6-6.4-7-12-7Zm0 11.2A4.2 4.2 0 1 1 12 7.8a4.2 4.2 0 0 1 0 8.4Zm0-1.9a2.3 2.3 0 1 0 0-4.6 2.3 2.3 0 0 0 0 4.6Z"></path>
                                        </svg>
                                    </button>
                                </div>
                                <div class="credential-state mt-1">
                                    <span class="status-chip @Model.RefPasswordStateClass">
                                        <span class="status-dot"></span>
                                        <span>@Model.RefPasswordStateLabel</span>
                                    </span>
                                </div>
                            </div>

                            <div class="server-note">
                                <strong>Current scope:</strong>
                                <span>the module controls startup mode, opening map and stock mutators. The Reflex runtime now removes the stock start rotation so the selected opening map wins.</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-12">
                    <div class="panel-card">
                        <div class="panel-card-header">
                            <span class="section-kicker">Advanced</span>
                            <h2 class="panel-title">Custom ruleset</h2>
                            <p class="panel-text mb-0">Override weapon damage, ammo, pickups and gravity without touching any config files. The panel generates <code>game/ruleset_&lt;name&gt;.cfg</code> automatically on each container start.</p>
                        </div>
                        <div class="panel-card-body vstack gap-4">
                            <div>
                                <label class="rule-toggle">
                                    <input asp-for="Input.CustomRulesEnabled"
                                           class="form-check-input"
                                           id="customRulesMaster" />
                                    <span>
                                        <strong>Enable custom ruleset</strong>
                                        <small>When disabled the server uses its default game constants.</small>
                                    </span>
                                </label>
                            </div>

                            <div id="customRulesBody" @(Model.Input.CustomRulesEnabled ? "" : "hidden")>
                                <div class="mb-4">
                                    <label asp-for="Input.CustomRulesetName" class="form-label"></label>
                                    <input asp-for="Input.CustomRulesetName"
                                           class="form-control"
                                           style="max-width:280px"
                                           placeholder="custom"
                                           maxlength="64" />
                                    <div class="form-hint">Lowercase letters, digits, underscores. Becomes <code>ruleset_&lt;name&gt;.cfg</code>.</div>
                                    <span asp-validation-for="Input.CustomRulesetName" class="text-danger small"></span>
                                </div>

                                <h3 class="mb-3" style="font-size:.9rem;text-transform:uppercase;letter-spacing:.05em;color:var(--bs-secondary-color,#6c757d)">Weapons</h3>
                                <div class="table-responsive mb-4">
                                    <table class="table table-sm align-middle mb-0" style="--bs-table-bg:transparent">
                                        <thead>
                                            <tr>
                                                <th style="width:220px">Weapon</th>
                                                <th style="width:120px">Direct DMG</th>
                                                <th style="width:120px">Splash DMG</th>
                                                <th style="width:60px" class="text-center">∞ Ammo</th>
                                                <th style="width:100px">Max ammo</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var weapon in Model.WeaponEntries)
                                            {
                                                var enabledKey = $"Input.WeaponEnabled[{weapon.Key}]";
                                                var isEnabled = Model.Input.WeaponEnabled.GetValueOrDefault(weapon.Key, true);
                                                var isInfinite = Model.Input.WeaponInfiniteAmmo.GetValueOrDefault(weapon.Key, false);
                                                <tr data-weapon-row="@weapon.Key" class="@(isEnabled ? "" : "opacity-50")">
                                                    <td>
                                                        <label class="d-flex align-items-center gap-2 mb-0 fw-semibold">
                                                            <input type="checkbox"
                                                                   name="Input.WeaponEnabled[@weapon.Key]"
                                                                   value="true"
                                                                   class="form-check-input weapon-toggle"
                                                                   data-weapon="@weapon.Key"
                                                                   @(isEnabled ? "checked" : null) />
                                                            @weapon.Label
                                                        </label>
                                                        <div class="form-hint mb-0">@weapon.Description</div>
                                                    </td>
                                                    <td>
                                                        <input type="number"
                                                               name="Input.WeaponDirectDamage[@weapon.Key]"
                                                               value="@(Model.Input.WeaponDirectDamage.TryGetValue(weapon.Key, out var dd) ? dd?.ToString() : null)"
                                                               class="form-control form-control-sm weapon-input"
                                                               data-weapon="@weapon.Key"
                                                               placeholder="@weapon.DefaultDirectDamage"
                                                               min="@weapon.DamageMin"
                                                               max="@weapon.DamageMax"
                                                               @(isEnabled ? null : "disabled") />
                                                    </td>
                                                    <td>
                                                        @if (weapon.HasSplashDamage)
                                                        {
                                                            <input type="number"
                                                                   name="Input.WeaponSplashDamage[@weapon.Key]"
                                                                   value="@(Model.Input.WeaponSplashDamage.TryGetValue(weapon.Key, out var sd) ? sd?.ToString() : null)"
                                                                   class="form-control form-control-sm weapon-input"
                                                                   data-weapon="@weapon.Key"
                                                                   placeholder="@weapon.DefaultSplashDamage"
                                                                   min="@weapon.DamageMin"
                                                                   max="@weapon.DamageMax"
                                                                   @(isEnabled ? null : "disabled") />
                                                        }
                                                        else
                                                        {
                                                            <span class="text-secondary">—</span>
                                                        }
                                                    </td>
                                                    <td class="text-center">
                                                        @if (weapon.HasAmmo)
                                                        {
                                                            <input type="checkbox"
                                                                   name="Input.WeaponInfiniteAmmo[@weapon.Key]"
                                                                   value="true"
                                                                   class="form-check-input infinite-ammo-toggle"
                                                                   data-weapon="@weapon.Key"
                                                                   @(isInfinite ? "checked" : null)
                                                                   @(isEnabled ? null : "disabled") />
                                                        }
                                                        else
                                                        {
                                                            <span class="text-secondary">—</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (weapon.HasAmmo)
                                                        {
                                                            <input type="number"
                                                                   name="Input.WeaponMaxAmmo[@weapon.Key]"
                                                                   value="@(Model.Input.WeaponMaxAmmo.TryGetValue(weapon.Key, out var ma) ? ma?.ToString() : null)"
                                                                   class="form-control form-control-sm weapon-input ammo-input"
                                                                   data-weapon="@weapon.Key"
                                                                   placeholder="@weapon.DefaultAmmo"
                                                                   min="1"
                                                                   max="9999"
                                                                   @(isEnabled && !isInfinite ? null : "disabled") />
                                                        }
                                                        else
                                                        {
                                                            <span class="text-secondary">—</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>

                                <h3 class="mb-3" style="font-size:.9rem;text-transform:uppercase;letter-spacing:.05em;color:var(--bs-secondary-color,#6c757d)">Pickups &amp; items</h3>
                                <div class="rule-toggle-list mb-4">
                                    @foreach (var pickup in Model.PickupEntries)
                                    {
                                        var isPickupEnabled = Model.Input.PickupEnabled.GetValueOrDefault(pickup.Key, true);
                                        <label class="rule-toggle">
                                            <input type="checkbox"
                                                   name="Input.PickupEnabled[@pickup.Key]"
                                                   value="true"
                                                   class="form-check-input"
                                                   @(isPickupEnabled ? "checked" : null) />
                                            <span>
                                                <strong>@pickup.Label</strong>
                                                <small>@pickup.Description</small>
                                            </span>
                                        </label>
                                    }
                                </div>

                                <h3 class="mb-3" style="font-size:.9rem;text-transform:uppercase;letter-spacing:.05em;color:var(--bs-secondary-color,#6c757d)">Global</h3>
                                <div style="max-width:280px">
                                    <label asp-for="Input.GravityOverride" class="form-label"></label>
                                    <input asp-for="Input.GravityOverride"
                                           class="form-control"
                                           type="number"
                                           min="50"
                                           max="3000"
                                           placeholder="800 (default)" />
                                    <div class="form-hint">Default is 800. Lower = floatier movement and bigger jumps.</div>
                                    <span asp-validation-for="Input.GravityOverride" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="panel-card sticky-actions">
                <div class="panel-card-body d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                    <div>
                        <h3 class="mb-1">Ready to apply</h3>
                        <p class="mb-0 text-secondary">Saving updates the Reflex Arena module config in SQLite. Save and restart also asks docker-agent to recreate the container with the new env vars.</p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit" asp-page-handler="Save" class="btn btn-primary btn-lg">Save settings</button>
                        <button type="submit" asp-page-handler="Apply" class="btn btn-outline-warning btn-lg" data-confirm-restart="true">Save and restart</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            // Master toggle: show/hide the whole ruleset body
            var master = document.getElementById('customRulesMaster');
            var body   = document.getElementById('customRulesBody');
            if (master && body) {
                master.addEventListener('change', function () {
                    body.hidden = !master.checked;
                });
            }

            // Weapon row: disable all inputs in the row when weapon is unchecked
            document.querySelectorAll('.weapon-toggle').forEach(function (cb) {
                cb.addEventListener('change', function () {
                    var key = cb.dataset.weapon;
                    var row = document.querySelector('[data-weapon-row="' + key + '"]');
                    if (!row) return;
                    var enabled = cb.checked;
                    row.classList.toggle('opacity-50', !enabled);
                    row.querySelectorAll('.weapon-input, .infinite-ammo-toggle').forEach(function (el) {
                        el.disabled = !enabled;
                    });
                    // Keep ammo input state in sync with infinite toggle
                    if (enabled) syncInfiniteAmmo(key);
                });
            });

            // Infinite ammo toggle: disable the max-ammo number input
            function syncInfiniteAmmo(key) {
                var inf     = document.querySelector('.infinite-ammo-toggle[data-weapon="' + key + '"]');
                var ammoIn  = document.querySelector('.ammo-input[data-weapon="' + key + '"]');
                if (inf && ammoIn) ammoIn.disabled = inf.checked;
            }

            document.querySelectorAll('.infinite-ammo-toggle').forEach(function (cb) {
                cb.addEventListener('change', function () { syncInfiniteAmmo(cb.dataset.weapon); });
            });
        })();
    </script>
}
