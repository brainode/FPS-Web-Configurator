@page
@model control_panel.Pages.SettingsModel
@{
    ViewData["Title"] = "Settings";
}

<section class="page-shell py-4 py-lg-5">
    <div class="container-xxl">
        <div class="page-header d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
            <div>
                <span class="section-kicker">Panel Settings</span>
                <h1 class="page-title mb-2">Overview Modules</h1>
                <p class="page-subtitle mb-0">Choose which game modules appear on the dashboard and in the primary navigation. Hidden modules keep their saved configuration and can be enabled again at any time.</p>
            </div>
            <div class="small text-secondary">Last updated: @Model.UpdatedLabel by @Model.UpdatedByLabel</div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="alert alert-success border-0 panel-alert" role="alert">@Model.SuccessMessage</div>
        }

        <form method="post" class="vstack gap-4">
            <div class="panel-card">
                <div class="panel-card-header">
                    <span class="section-kicker">Visibility</span>
                    <h2 class="panel-title">Active game modules</h2>
                    <p class="panel-text mb-0">Overview and Settings always stay visible. These toggles control only the game modules.</p>
                </div>
                <div class="panel-card-body vstack gap-3">
                    @foreach (var module in Model.Modules)
                    {
                        <label class="rule-toggle justify-content-between align-items-center">
                            <span>
                                <strong>@module.DisplayName</strong>
                                <small>Show this server on the dashboard and in the top navigation.</small>
                            </span>
                            <span class="d-flex align-items-center gap-3">
                                <span class="status-chip @(Model.IsEnabled(module.GameKey) ? "status-running" : "status-neutral")">
                                    <span class="status-dot"></span>
                                    <span>@(Model.IsEnabled(module.GameKey) ? "Visible" : "Hidden")</span>
                                </span>
                                <span class="form-check form-switch m-0">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="Input.EnabledGameKeys"
                                           value="@module.GameKey"
                                           @(Model.IsEnabled(module.GameKey) ? "checked" : null) />
                                </span>
                            </span>
                        </label>
                    }
                </div>
            </div>

            <div class="panel-card sticky-actions">
                <div class="panel-card-body d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                    <div>
                        <h3 class="mb-1">Ready to apply</h3>
                        <p class="mb-0 text-secondary">Changes take effect immediately on the overview and in the top navigation.</p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit" asp-page-handler="Save" class="btn btn-primary btn-lg">Save settings</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>
